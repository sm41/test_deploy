    <updated>2026-03-30T01:20:00+09:00</updated>
    <content type="html">        &lt;body&gt;
            &lt;img src="https://image-cdn.tver.jp/images/content/thumbnail/series/xlarge/srw0372p4y.jpg"&gt;

            &lt;hr&gt;

            &lt;div&gt;🎞️ エレベーターは止まらない
                &lt;a href="https://tver.jp/series/srw0372p4y" target="_blank" rel="noopener noreferrer"&gt;🔗&lt;/a&gt;
            &lt;/div&gt;

            &lt;table&gt;
