    <updated>2026-07-20T23:09:00+09:00</updated>
    <link href="https://tver.jp/episodes/epks0s4qy8" />
    <content>        &lt;body&gt;
            &lt;img src="https://image-cdn.tver.jp/images/content/thumbnail/series/xlarge/src565pb2j.jpg"&gt;
            &lt;hr&gt;
            &lt;div&gt;🎞️ GTO
                &lt;a href="https://tver.jp/series/src565pb2j" target="_blank" rel="noopener noreferrer"&gt;🔗&lt;/a&gt;
            &lt;/div&gt;
            &lt;table&gt;
