                &lt;th&gt;
                    &lt;td&gt;
                        &lt;div&gt;🗓️ 放送&amp;emsp; : 3月27日(金)放送分&lt;/div&gt;
                        &lt;div&gt;📡 放送局 : TBS&lt;/div&gt;
                    &lt;/td&gt;
