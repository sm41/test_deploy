    <content type="html">        &lt;body&gt;
            &lt;img src="https://image-cdn.tver.jp/images/content/thumbnail/series/xlarge/sruts7aghq.jpg"&gt;

            &lt;hr&gt;

            &lt;div&gt;🎞️ 余命３ヶ月のサレ夫
                &lt;a href="https://tver.jp/series/sruts7aghq" target="_blank" rel="noopener noreferrer"&gt;🔗&lt;/a&gt;
            &lt;/div&gt;

            &lt;table&gt;
