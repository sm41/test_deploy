            &lt;div&gt;🎞️ 失恋カルタ
                &lt;a href="https://tver.jp/series/srr8o52a7s" target="_blank" rel="noopener noreferrer"&gt;🔗&lt;/a&gt;
            &lt;/div&gt;

            &lt;table&gt;
                &lt;th&gt;
                    &lt;td&gt;
                        &lt;div&gt;🕘 配信開始 : 2026年_04月29日(水)_01時56分&lt;/div&gt;
                        &lt;div&gt;🕓 配信終了 : 2026年_05月06日(水)_01時55分&lt;/div&gt;
                    &lt;/td&gt;
                &lt;/th&gt;
                &lt;th&gt;
                    &lt;td&gt;
                        &lt;div&gt;🗓️ 放送&amp;emsp; : 4月28日(火)放送分&lt;/div&gt;
                        &lt;div&gt;📡 放送局 : MBS毎日放送&lt;/div&gt;
                    &lt;/td&gt;
