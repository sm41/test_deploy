    <content type="html">        &lt;body&gt;
            &lt;img src="https://image-cdn.tver.jp/images/content/thumbnail/series/xlarge/srpleivvzt.jpg"&gt;

            &lt;hr&gt;

            &lt;div&gt;🎞️ リブート
                &lt;a href="https://tver.jp/series/srpleivvzt" target="_blank" rel="noopener noreferrer"&gt;🔗&lt;/a&gt;
